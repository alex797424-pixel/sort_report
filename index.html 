<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>氣泡排序工具</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 20px;
        }
        input {
            margin: 5px 0;
        }
        .page {
            display: none;
        }
        .page.active {
            display: block;
        }
    </style>
</head>
<body>
    <!-- 首頁 -->
    <div id="home" class="page active">
        <h1>歡迎來到排序工具</h1>
        <p>這是一個簡單的工具，您可以使用氣泡排序來排序數字。</p>
        <button onclick="goToPage('bubbleSort')">開始使用氣泡排序</button>
    </div>

    <!-- 氣泡排序頁面 -->
    <div id="bubbleSort" class="page">
        <h1>氣泡排序</h1>
        <p>輸入數字（以逗號分隔）：</p>
        <input type="text" id="numbers" placeholder="例如：5,3,8,6,2">
        <button onclick="sortNumbers()">排序</button>
        <h2>排序結果：</h2>
        <p id="result"></p>
        <button onclick="goToPage('home')">回首頁</button>
    </div>

    <script>
        // 切換頁面
        function goToPage(pageId) {
            const pages = document.querySelectorAll('.page');
            pages.forEach(page => page.classList.remove('active'));
            document.getElementById(pageId).classList.add('active');
        }

        // 氣泡排序函式
        function bubbleSort(arr) {
            let n = arr.length;
            for (let i = 0; i < n - 1; i++) {
                for (let j = 0; j < n - i - 1; j++) {
                    if (arr[j] > arr[j + 1]) {
                        // 交換元素
                        let temp = arr[j];
                        arr[j] = arr[j + 1];
                        arr[j + 1] = temp;
                    }
                }
            }
            return arr;
        }

        // 排序數字
        function sortNumbers() {
            const input = document.getElementById('numbers').value;
            const numArray = input.split(',').map(Number); // 將輸入轉換為數字陣列
            if (numArray.some(isNaN)) {
                document.getElementById('result').textContent = '請輸入有效的數字！';
                return;
            }
            const sortedArray = bubbleSort(numArray);
            document.getElementById('result').textContent = sortedArray.join(', ');
        }
    </script>
</body>
</html>